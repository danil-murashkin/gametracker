{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gametracker.local/schemas/character_instance.schema.json",
  "title": "Gametracker Character Instance",
  "type": "object",
  "required": ["scenario_name", "instance_id", "stats", "recipes"],
  "additionalProperties": false,
  "properties": {
    "scenario_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Must match character_model.scenario_name. Engine loads that scenario"
    },
    "instance_id": {
      "type": "string",
      "pattern": "^[a-f0-9]+$",
      "description": "PDA / character id, hex without separators"
    },
    "stats": {
      "type": "array",
      "items": { "$ref": "#/$defs/stat_value" },
      "description": "Current stat values for this character"
    },
    "recipes": {
      "type": "array",
      "items": { "$ref": "#/$defs/recipe_runtime" },
      "description": "Recipes on this character: applied preps, equipped items, world mechanics, timed markers for synergy"
    }
  },
  "$defs": {
    "stat_value": {
      "type": "object",
      "required": ["name", "value", "buff_rate", "buff_duration", "buff_coefficient"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "value": { "type": "number" },
        "buff_rate": {
          "type": "number",
          "description": "Current base per-second change"
        },
        "buff_duration": {
          "type": "number",
          "minimum": 0,
          "description": "Remaining buff/debuff timer on this stat. 0 — no timed buff. Ticks down each second"
        },
        "buff_coefficient": {
          "type": "number",
          "description": "Current multiplier for buff_rate. Default 1"
        }
      }
    },
    "recipe_runtime": {
      "type": "object",
      "required": [
        "name",
        "status",
        "duration_left_sec",
        "uses_applied",
        "uses_left",
        "signature"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Recipe name from scenario"
        },
        "status": {
          "type": "string",
          "enum": ["active", "pending"],
          "description": "active — on character now (effects already applied if instant); pending — waiting for start/trigger"
        },
        "duration_left_sec": {
          "type": "number",
          "minimum": 0,
          "description": "Seconds until recipe is removed from character. 0 — no timed presence (passive/equipped until unequip). Not part of signature"
        },
        "uses_applied": {
          "type": "number",
          "minimum": 0
        },
        "uses_left": {
          "type": "number",
          "minimum": 0
        },
        "signature": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "HMAC-SHA256 over name, status, uses_applied, uses_left"
        }
      }
    }
  }
}
