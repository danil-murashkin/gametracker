{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gametracker.local/schemas/character_model.schema.json",
  "title": "Gametracker Character Model",
  "type": "object",
  "required": ["scenario_name", "stats", "recipes"],
  "additionalProperties": false,
  "properties": {
    "scenario_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Unique scenario id: fallout, stalker, tarkov"
    },
    "meta": {
      "type": "object",
      "properties": {
        "title": { "type": "string" }
      }
    },
    "stats": {
      "type": "array",
      "items": { "$ref": "#/$defs/stat" }
    },
    "recipes": {
      "type": "array",
      "items": { "$ref": "#/$defs/recipe" }
    }
  },
  "$defs": {
    "stat": {
      "type": "object",
      "required": [
        "name",
        "description",
        "title",
        "kind",
        "min",
        "max",
        "default",
        "buff_rate",
        "buff_duration",
        "buff_coefficient"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Unique technical name within scenario (among stats)"
        },
        "description": { "type": "string" },
        "title": {
          "type": "string",
          "description": "Display title for UI"
        },
        "kind": {
          "type": "string",
          "enum": ["none", "instant", "timed", "passive"],
          "description": "Stat mode: none — not engaged, ignored by engine; passive — always active; instant — one-shot change; timed — buff_duration active"
        },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "default": { "type": "number" },
        "buff_rate": {
          "type": "number",
          "description": "Base per-second change. 0 — no timed change. Effective change = buff_rate * buff_coefficient"
        },
        "buff_duration": {
          "type": "number",
          "minimum": 0,
          "description": "Buff/debuff timer on this stat (seconds remaining at runtime). 0 — no timed buff. Set by set_buff_duration; ticks down each second"
        },
        "buff_coefficient": {
          "type": "number",
          "description": "Multiplier for buff_rate. Default 1. Effective delta = buff_rate * buff_coefficient. Set by set_buff_coefficient / add_buff_coefficient"
        }
      }
    },
    "recipe": {
      "type": "object",
      "required": [
        "name",
        "description",
        "title",
        "kind",
        "uses",
        "uses_max",
        "duration_sec",
        "while",
        "effects",
        "start",
        "stop",
        "triggers",
        "signature"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Unique technical name within scenario (among recipes)"
        },
        "description": { "type": "string" },
        "title": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["none", "instant", "timed", "passive"],
          "description": "Recipe mode: none — off; instant — effects once on apply, optional duration_sec presence; timed — duration_sec then removed; passive — while active (armor until unequip)"
        },
        "uses": {
          "type": "number",
          "minimum": 0,
          "description": "Initial uses_left when a recipe instance is minted. Not mutated at runtime"
        },
        "uses_max": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum uses. 0 — unlimited (uses is not spent)"
        },
        "duration_sec": {
          "type": "number",
          "minimum": 0,
          "description": "How long the recipe stays on the character after apply (timer). 0 — no timer: equipped armor / passive stay until unequip or stop"
        },
        "while": { "type": "string" },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" }
        },
        "start": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stop": {
          "type": "array",
          "items": { "type": "string" }
        },
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/$defs/trigger" }
        },
        "signature": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "HMAC-SHA256 hex over recipe payload (all fields except signature) and scenario_name. Engine rejects recipe if signature mismatch"
        }
      }
    },
    "trigger": {
      "type": "object",
      "required": ["when", "edge", "effects", "start", "stop"],
      "additionalProperties": false,
      "properties": {
        "when": { "type": "string" },
        "edge": {
          "type": "string",
          "enum": ["while_true", "once", "on_rise", "on_fall"]
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/effect" }
        },
        "start": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stop": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "effect": {
      "type": "object",
      "required": ["target", "operation", "expr"],
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "description": "stat name"
        },
        "operation": {
          "type": "string",
          "enum": [
            "set",
            "add",
            "set_buff_rate",
            "add_buff_rate",
            "set_buff_duration",
            "set_buff_coefficient",
            "add_buff_coefficient"
          ]
        },
        "expr": { "type": "string" }
      }
    }
  }
}
